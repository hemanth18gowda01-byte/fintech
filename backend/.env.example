# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/finance_db?retryWrites=true&w=majority

# JWT Secret (Generate: openssl rand -hex 32)
JWT_SECRET_KEY=change-this-to-random-secret-key

# Fernet Key (Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=generate-and-paste-here

# Port
PORT=5000
